<!-- Win11 暗色主题 -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 主色调 -->
    <Color x:Key="AccentColor">#60CDFF</Color>
    <Color x:Key="AccentLightColor">#005FB8</Color>

    <!-- 背景色 -->
    <Color x:Key="WindowBgColor">#202020</Color>
    <Color x:Key="CardBgColor">#2D2D2D</Color>
    <Color x:Key="CardBgHoverColor">#383838</Color>
    <Color x:Key="CardBgPressedColor">#404040</Color>
    <Color x:Key="SurfaceColor">#2D2D2D</Color>
    <Color x:Key="MicaColor">#202020</Color>

    <!-- 文字色 -->
    <Color x:Key="TextColor">#FFFFFF</Color>
    <Color x:Key="TextSecondaryColor">#B3B3B3</Color>
    <Color x:Key="TextTertiaryColor">#808080</Color>
    <Color x:Key="TextOnAccentColor">#000000</Color>

    <!-- 分隔线 -->
    <Color x:Key="DividerColor">#404040</Color>
    <Color x:Key="DividerLightColor">#333333</Color>

    <!-- 控件色 -->
    <Color x:Key="ControlBgColor">#333333</Color>
    <Color x:Key="ControlBgHoverColor">#444444</Color>
    <Color x:Key="ControlBgPressedColor">#555555</Color>
    <Color x:Key="ControlBorderColor">#505050</Color>
    <Color x:Key="ControlBorderHoverColor">#666666</Color>

    <!-- 输入框 -->
    <Color x:Key="InputBgColor">#1E1E1E</Color>
    <Color x:Key="InputBorderColor">#505050</Color>
    <Color x:Key="InputBorderFocusColor">#60CDFF</Color>

    <!-- 状态色 -->
    <Color x:Key="SuccessColor">#6CCB5F</Color>
    <Color x:Key="WarningColor">#FCE100</Color>
    <Color x:Key="ErrorColor">#FF99A4</Color>

    <!-- 选区覆盖层 -->
    <Color x:Key="OverlayDimColor">#AA000000</Color>
    <Color x:Key="SelectionBorderColor">#60CDFF</Color>
    <Color x:Key="WindowHighlightColor">#FF8C5A</Color>

    <!-- 画布 -->
    <Color x:Key="CanvasBgColor">#1A1A1A</Color>

    <!-- Brush 资源 -->
    <SolidColorBrush x:Key="WindowBgBrush" Color="{StaticResource WindowBgColor}"/>
    <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource CardBgColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource TextTertiaryColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentLightBrush" Color="{StaticResource AccentLightColor}"/>
    <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource DividerColor}"/>
    <SolidColorBrush x:Key="ControlBgBrush" Color="{StaticResource ControlBgColor}"/>
    <SolidColorBrush x:Key="ControlBgHoverBrush" Color="{StaticResource ControlBgHoverColor}"/>
    <SolidColorBrush x:Key="ControlBgPressedBrush" Color="{StaticResource ControlBgPressedColor}"/>
    <SolidColorBrush x:Key="ControlBorderBrush" Color="{StaticResource ControlBorderColor}"/>
    <SolidColorBrush x:Key="InputBgBrush" Color="{StaticResource InputBgColor}"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="{StaticResource InputBorderColor}"/>
    <SolidColorBrush x:Key="InputBorderFocusBrush" Color="{StaticResource InputBorderFocusColor}"/>
    <SolidColorBrush x:Key="CanvasBgBrush" Color="{StaticResource CanvasBgColor}"/>
    <SolidColorBrush x:Key="OverlayDimBrush" Color="{StaticResource OverlayDimColor}"/>
    <SolidColorBrush x:Key="SelectionBorderBrush" Color="{StaticResource SelectionBorderColor}"/>

</ResourceDictionary>
