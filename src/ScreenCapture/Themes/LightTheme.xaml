<!-- Win11 亮色主题 -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 主色调 -->
    <Color x:Key="AccentColor">#005FB8</Color>
    <Color x:Key="AccentLightColor">#60CDFF</Color>

    <!-- 背景色 -->
    <Color x:Key="WindowBgColor">#F3F3F3</Color>
    <Color x:Key="CardBgColor">#FFFFFF</Color>
    <Color x:Key="CardBgHoverColor">#F9F9F9</Color>
    <Color x:Key="CardBgPressedColor">#F0F0F0</Color>
    <Color x:Key="SurfaceColor">#FBFBFB</Color>
    <Color x:Key="MicaColor">#F3F3F3</Color>

    <!-- 文字色 -->
    <Color x:Key="TextColor">#1A1A1A</Color>
    <Color x:Key="TextSecondaryColor">#616161</Color>
    <Color x:Key="TextTertiaryColor">#9E9E9E</Color>
    <Color x:Key="TextOnAccentColor">#FFFFFF</Color>

    <!-- 分隔线 -->
    <Color x:Key="DividerColor">#E8E8E8</Color>
    <Color x:Key="DividerLightColor">#F0F0F0</Color>

    <!-- 控件色 -->
    <Color x:Key="ControlBgColor">#FFFFFF</Color>
    <Color x:Key="ControlBgHoverColor">#E9E9E9</Color>
    <Color x:Key="ControlBgPressedColor">#DADADA</Color>
    <Color x:Key="ControlBorderColor">#E0E0E0</Color>
    <Color x:Key="ControlBorderHoverColor">#C8C8C8</Color>

    <!-- 输入框 -->
    <Color x:Key="InputBgColor">#FFFFFF</Color>
    <Color x:Key="InputBorderColor">#C8C8C8</Color>
    <Color x:Key="InputBorderFocusColor">#005FB8</Color>

    <!-- 状态色 -->
    <Color x:Key="SuccessColor">#0F7B0F</Color>
    <Color x:Key="WarningColor">#9D5D00</Color>
    <Color x:Key="ErrorColor">#C42B1C</Color>

    <!-- 选区覆盖层 -->
    <Color x:Key="OverlayDimColor">#99000000</Color>
    <Color x:Key="SelectionBorderColor">#005FB8</Color>
    <Color x:Key="WindowHighlightColor">#FF6B35</Color>

    <!-- 画布 -->
    <Color x:Key="CanvasBgColor">#E8E8E8</Color>

    <!-- Brush 资源 -->
    <SolidColorBrush x:Key="WindowBgBrush" Color="{StaticResource WindowBgColor}"/>
    <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource CardBgColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource TextTertiaryColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentLightBrush" Color="{StaticResource AccentLightColor}"/>
    <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource DividerColor}"/>
    <SolidColorBrush x:Key="ControlBgBrush" Color="{StaticResource ControlBgColor}"/>
    <SolidColorBrush x:Key="ControlBgHoverBrush" Color="{StaticResource ControlBgHoverColor}"/>
    <SolidColorBrush x:Key="ControlBgPressedBrush" Color="{StaticResource ControlBgPressedColor}"/>
    <SolidColorBrush x:Key="ControlBorderBrush" Color="{StaticResource ControlBorderColor}"/>
    <SolidColorBrush x:Key="InputBgBrush" Color="{StaticResource InputBgColor}"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="{StaticResource InputBorderColor}"/>
    <SolidColorBrush x:Key="InputBorderFocusBrush" Color="{StaticResource InputBorderFocusColor}"/>
    <SolidColorBrush x:Key="CanvasBgBrush" Color="{StaticResource CanvasBgColor}"/>
    <SolidColorBrush x:Key="OverlayDimBrush" Color="{StaticResource OverlayDimColor}"/>
    <SolidColorBrush x:Key="SelectionBorderBrush" Color="{StaticResource SelectionBorderColor}"/>

</ResourceDictionary>
