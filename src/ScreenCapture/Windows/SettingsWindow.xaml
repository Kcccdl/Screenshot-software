<Window x:Class="ScreenCapture.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置" Width="420" Height="320"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBgBrush}"
        WindowStyle="SingleBorderWindow">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="快捷键设置" FontSize="16" FontWeight="Bold"
                   Foreground="{DynamicResource TextBrush}" Margin="0,0,0,15"/>

        <Border Grid.Row="1" Background="{DynamicResource CardBgBrush}" CornerRadius="6"
                Padding="15" Margin="0,0,0,15"
                BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="截图快捷键" Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="12" Margin="0,0,0,8"/>
                <TextBlock x:Name="CurrentHotkeyText" Text="PrintScreen"
                           Foreground="{DynamicResource AccentBrush}" FontSize="18" FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="{DynamicResource CardBgBrush}" CornerRadius="6"
                Padding="15" Margin="0,0,0,15"
                BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="按下新的快捷键组合..." Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="12" Margin="0,0,0,8"/>
                <Border Background="{DynamicResource InputBgBrush}" CornerRadius="4" Padding="10"
                        BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1">
                    <TextBlock x:Name="NewHotkeyText" Text="请按下快捷键..."
                               Foreground="{DynamicResource TextTertiaryBrush}" FontSize="14"
                               HorizontalAlignment="Center"/>
                </Border>
                <TextBlock Text="支持 Ctrl/Alt/Shift + 任意键的组合" Foreground="{DynamicResource TextTertiaryBrush}"
                           FontSize="11" Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="ResetButton" Content="恢复默认" Style="{DynamicResource Win11Button}"
                    Padding="16,8" Margin="0,0,8,0" Click="ResetButton_Click"/>
            <Button x:Name="SaveButton" Content="保存" Style="{DynamicResource Win11AccentButton}"
                    Padding="16,8" Click="SaveButton_Click"/>
            <Button Content="取消" Style="{DynamicResource Win11Button}"
                    Padding="16,8" Margin="8,0,0,0" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
