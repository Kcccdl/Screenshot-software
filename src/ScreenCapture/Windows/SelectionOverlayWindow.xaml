<!-- 选区覆盖层窗口 -->
<!-- 全屏窗口，截图作为背景，用户拖拽选择截图区域 -->
<Window x:Class="ScreenCapture.Windows.SelectionOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        WindowState="Maximized"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Cursor="Cross"
        Background="#FF000000"
        KeyDown="Window_KeyDown"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseLeftButtonUp="Window_MouseLeftButtonUp"
        MouseMove="Window_MouseMove"
        MouseDoubleClick="Window_MouseDoubleClick"
        Loaded="Window_Loaded">
    <Grid x:Name="RootGrid">
        <!-- 全屏截图背景（拉伸填满窗口） -->
        <Image x:Name="BackgroundImage" Stretch="UniformToFill" />

        <!-- 半透明遮罩层（覆盖整个窗口，选区部分会被裁掉） -->
        <Canvas x:Name="OverlayCanvas" Background="Transparent"
                ClipToBounds="True" IsHitTestVisible="False">
            <!-- 选区外部的半透明遮罩（上下左右四个矩形） -->
            <Rectangle x:Name="DimTop" Fill="#99000000" />
            <Rectangle x:Name="DimLeft" Fill="#99000000" />
            <Rectangle x:Name="DimRight" Fill="#99000000" />
            <Rectangle x:Name="DimBottom" Fill="#99000000" />

            <!-- 选区边框（蓝色虚线） -->
            <Rectangle x:Name="SelectionBorder"
                       Stroke="#00BFFF" StrokeThickness="2"
                       StrokeDashArray="4 2" Fill="Transparent"
                       Visibility="Collapsed" />

            <!-- 智能窗口检测高亮框（橙色） -->
            <Rectangle x:Name="WindowHighlight"
                       Stroke="#FF6B35" StrokeThickness="3"
                       Fill="#30FF6B35" Visibility="Collapsed" />

            <!-- 窗口标题标签 -->
            <Border x:Name="WindowTitleBorder"
                    Background="#E0333333" CornerRadius="4"
                    Padding="8,4" Visibility="Collapsed">
                <TextBlock x:Name="WindowTitleText"
                           Foreground="White" FontSize="12"
                           FontFamily="Microsoft YaHei"/>
            </Border>

            <!-- 选区尺寸标签 -->
            <Border x:Name="DimensionBorder"
                    Background="#E0333333" CornerRadius="4"
                    Padding="8,4" Visibility="Collapsed">
                <TextBlock x:Name="DimensionText"
                           Foreground="White" FontSize="12"
                           FontFamily="Consolas"/>
            </Border>

            <!-- 十字准线 -->
            <Line x:Name="CrosshairH" Stroke="#60FFFFFF" StrokeThickness="1" Visibility="Collapsed" />
            <Line x:Name="CrosshairV" Stroke="#60FFFFFF" StrokeThickness="1" Visibility="Collapsed" />
        </Canvas>

        <!-- 操作提示（放在最上层，可接收点击） -->
        <Border Background="#C0333333" CornerRadius="4" Padding="12,6"
                HorizontalAlignment="Left" VerticalAlignment="Top"
                Margin="20,20,0,0" IsHitTestVisible="False">
            <TextBlock Foreground="White" FontSize="13" FontFamily="Microsoft YaHei">
                拖拽选择区域 | 双击选中窗口 | ESC 取消 | 右键取消
            </TextBlock>
        </Border>
    </Grid>
</Window>
