<Window x:Class="ScreenCapture.Windows.AnnotationEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ScreenCapture.ViewModels"
        xmlns:enums="clr-namespace:ScreenCapture.Models.Enums"
        Title="截图标注"
        WindowState="Maximized"
        WindowStyle="SingleBorderWindow"
        Background="{DynamicResource WindowBgBrush}"
        KeyDown="Window_KeyDown"
        Closing="Window_Closing">
    <Window.DataContext>
        <vm:AnnotationEditorViewModel x:Name="ViewModel" />
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 工具栏1：形状、颜色、粗细 -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,0,1" Padding="6,4">
            <StackPanel Orientation="Horizontal">
                <ToggleButton Content="&#x25A1; 矩形" Style="{DynamicResource ToolToggleButton}"
                              IsChecked="True" Tag="{x:Static enums:ShapeType.Rectangle}" Click="ToolButton_Click"/>
                <ToggleButton Content="&#x25CB; 圆形" Style="{DynamicResource ToolToggleButton}"
                              Tag="{x:Static enums:ShapeType.Ellipse}" Click="ToolButton_Click"/>
                <ToggleButton Content="&#x2192; 箭头" Style="{DynamicResource ToolToggleButton}"
                              Tag="{x:Static enums:ShapeType.Arrow}" Click="ToolButton_Click"/>
                <ToggleButton Content="&#x2500; 直线" Style="{DynamicResource ToolToggleButton}"
                              Tag="{x:Static enums:ShapeType.Line}" Click="ToolButton_Click"/>
                <ToggleButton Content="&#x270E; 画笔" Style="{DynamicResource ToolToggleButton}"
                              Tag="{x:Static enums:ShapeType.FreeDraw}" Click="ToolButton_Click"/>
                <ToggleButton Content="&#x270D; 文字" Style="{DynamicResource ToolToggleButton}"
                              Tag="{x:Static enums:ShapeType.Text}" Click="ToolButton_Click"/>
                <ToggleButton Content="&#x25A6; 马赛克" Style="{DynamicResource ToolToggleButton}"
                              Tag="{x:Static enums:ShapeType.Mosaic}" Click="ToolButton_Click"/>
                <ToggleButton Content="&#x2776; 序号" Style="{DynamicResource ToolToggleButton}"
                              Tag="{x:Static enums:ShapeType.SequenceNumber}" Click="ToolButton_Click"/>

                <Border Width="1" Background="{DynamicResource DividerBrush}" Margin="8,2"/>

                <!-- 颜色 -->
                <TextBlock Text="颜色:" Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="8,0,4,0"/>
                <Button Style="{DynamicResource ToolbarButton}" Click="ColorButton_Click" Tag="#FF0000" Width="24" Height="24" Margin="2"><Ellipse Fill="Red" Width="16" Height="16"/></Button>
                <Button Style="{DynamicResource ToolbarButton}" Click="ColorButton_Click" Tag="#00FF00" Width="24" Height="24" Margin="2"><Ellipse Fill="Green" Width="16" Height="16"/></Button>
                <Button Style="{DynamicResource ToolbarButton}" Click="ColorButton_Click" Tag="#0000FF" Width="24" Height="24" Margin="2"><Ellipse Fill="Blue" Width="16" Height="16"/></Button>
                <Button Style="{DynamicResource ToolbarButton}" Click="ColorButton_Click" Tag="#FFFF00" Width="24" Height="24" Margin="2"><Ellipse Fill="Yellow" Width="16" Height="16"/></Button>
                <Button Style="{DynamicResource ToolbarButton}" Click="ColorButton_Click" Tag="#FF6600" Width="24" Height="24" Margin="2"><Ellipse Fill="Orange" Width="16" Height="16"/></Button>
                <Button Style="{DynamicResource ToolbarButton}" Click="ColorButton_Click" Tag="#FFFFFF" Width="24" Height="24" Margin="2"><Ellipse Fill="White" Width="16" Height="16"/></Button>
                <Button Style="{DynamicResource ToolbarButton}" Click="ColorButton_Click" Tag="#000000" Width="24" Height="24" Margin="2"><Ellipse Fill="Black" Width="16" Height="16" Stroke="Gray" StrokeThickness="1"/></Button>

                <Border Width="1" Background="{DynamicResource DividerBrush}" Margin="8,2"/>

                <!-- 粗细 -->
                <TextBlock Text="粗细:" Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="8,0,4,0"/>
                <Slider x:Name="ThicknessSlider" Minimum="1" Maximum="10" Value="2" Width="80"
                        VerticalAlignment="Center" ValueChanged="ThicknessSlider_ValueChanged"/>
                <TextBlock x:Name="ThicknessLabel" Text="2" Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="4,0"/>

                <Border Width="1" Background="{DynamicResource DividerBrush}" Margin="8,2"/>

                <Button Content="&#x21B6; 撤销" Style="{DynamicResource ToolbarButton}" Command="{Binding UndoCommand}"/>
                <Button Content="&#x21B7; 重做" Style="{DynamicResource ToolbarButton}" Command="{Binding RedoCommand}"/>
                <Button Content="&#x2716; 清除" Style="{DynamicResource ToolbarButton}" Command="{Binding ClearAllCommand}"/>
            </StackPanel>
        </Border>

        <!-- 工具栏2：文字设置 -->
        <Border Grid.Row="1" Background="{DynamicResource CardBgBrush}"
                BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,0,1" Padding="6,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="文字:" Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="4,0,6,0"/>

                <TextBlock Text="字体" Foreground="{DynamicResource TextTertiaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ComboBox x:Name="FontFamilyCombo" Width="140" VerticalAlignment="Center"
                          Style="{DynamicResource Win11ComboBox}"
                          SelectionChanged="FontFamily_Changed" SelectedIndex="0">
                    <ComboBoxItem Content="微软雅黑" Tag="Microsoft YaHei"/>
                    <ComboBoxItem Content="宋体" Tag="SimSun"/>
                    <ComboBoxItem Content="黑体" Tag="SimHei"/>
                    <ComboBoxItem Content="楷体" Tag="KaiTi"/>
                    <ComboBoxItem Content="仿宋" Tag="FangSong"/>
                    <ComboBoxItem Content="Arial" Tag="Arial"/>
                    <ComboBoxItem Content="Times New Roman" Tag="Times New Roman"/>
                    <ComboBoxItem Content="Consolas" Tag="Consolas"/>
                </ComboBox>

                <Border Width="1" Background="{DynamicResource DividerBrush}" Margin="10,2"/>

                <TextBlock Text="字号" Foreground="{DynamicResource TextTertiaryBrush}"
                           VerticalAlignment="Center" Margin="10,0,4,0"/>
                <ComboBox x:Name="FontSizeCombo" Width="55" VerticalAlignment="Center"
                          Style="{DynamicResource Win11ComboBox}"
                          SelectionChanged="FontSize_Changed">
                    <ComboBoxItem Content="12" Tag="12"/>
                    <ComboBoxItem Content="14" Tag="14"/>
                    <ComboBoxItem Content="16" IsSelected="True" Tag="16"/>
                    <ComboBoxItem Content="18" Tag="18"/>
                    <ComboBoxItem Content="20" Tag="20"/>
                    <ComboBoxItem Content="24" Tag="24"/>
                    <ComboBoxItem Content="28" Tag="28"/>
                    <ComboBoxItem Content="32" Tag="32"/>
                    <ComboBoxItem Content="36" Tag="36"/>
                    <ComboBoxItem Content="48" Tag="48"/>
                </ComboBox>

                <Border Width="1" Background="{DynamicResource DividerBrush}" Margin="10,2"/>

                <ToggleButton x:Name="BoldToggle" Content="B" FontSize="13" FontWeight="Bold"
                              Style="{DynamicResource ToolToggleButton}" Padding="6,3" Margin="2"
                              Click="Bold_Changed"/>
                <ToggleButton x:Name="ItalicToggle" Content="I" FontSize="13" FontStyle="Italic"
                              Style="{DynamicResource ToolToggleButton}" Padding="6,3" Margin="2"
                              Click="Italic_Changed"/>
                <ToggleButton x:Name="UnderlineToggle"
                              Style="{DynamicResource ToolToggleButton}" Padding="6,3" Margin="2"
                              Click="Underline_Changed">
                    <TextBlock TextDecorations="Underline" Text="U" FontSize="13"/>
                </ToggleButton>
                <ToggleButton x:Name="StrikethroughToggle"
                              Style="{DynamicResource ToolToggleButton}" Padding="6,3" Margin="2"
                              Click="Strikethrough_Changed">
                    <TextBlock TextDecorations="Strikethrough" Text="S" FontSize="13"/>
                </ToggleButton>
            </StackPanel>
        </Border>

        <!-- 画布 -->
        <Border Grid.Row="2" Background="{DynamicResource CanvasBgBrush}" Margin="4" CornerRadius="4">
            <Canvas x:Name="AnnotationCanvas"
                    ClipToBounds="True"
                    Background="Transparent"
                    MouseDown="Canvas_MouseDown"
                    MouseMove="Canvas_MouseMove"
                    MouseUp="Canvas_MouseUp"/>
        </Border>

        <!-- 底部操作栏 -->
        <Border Grid.Row="3" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,1,0,0" Padding="6,4">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock x:Name="StatusTextBlock" Text="{Binding StatusText}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="8,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <Button Content="&#x1F4CB; 复制到剪切板" Style="{DynamicResource Win11AccentButton}"
                            Command="{Binding CopyToClipboardCommand}" Padding="12,6" FontSize="13"/>
                    <Button Content="&#x1F4BE; 另存为..." Style="{DynamicResource Win11Button}"
                            Command="{Binding SaveAsCommand}" Padding="12,6" FontSize="13"/>
                    <Button Content="&#x2716; 取消" Style="{DynamicResource Win11Button}"
                            Click="CancelButton_Click" Padding="12,6" FontSize="13"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
